# Web Push Configuration
# Generate VAPID keys using the script: node scripts/generate-vapid-keys.js

# VAPID Public Key (exposed to client)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# VAPID Private Key (keep secret, server-side only)
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# VAPID Subject (must be a mailto URL or your website URL)
VAPID_SUBJECT=mailto:your-email@example.com
